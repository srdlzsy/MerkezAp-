{
  "Auth": {
    "AllowSelfRegistration": true
  },
  "Hosting": {
    "EnableSwagger": true,
    "ExposeDiagnosticsOnRoot": true,
    "EnforceHttps": false,
    "UseHsts": false
  },
  "StartupTasks": {
    "ApplyAuthMigrations": true,
    "SynchronizePermissionCatalog": true,
    "SynchronizeWarehouseUsers": true
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200"
    ],
    "AllowCredentials": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
