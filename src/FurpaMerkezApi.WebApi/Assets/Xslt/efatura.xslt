					<xsl:if test=".!=''">
						<xsl:text>Kapı No:</xsl:text>
						<xsl:apply-templates/>
						<xsl:text>&#xA0;</xsl:text>
						<br/>
					</xsl:if>
				</xsl:for-each>
				<xsl:for-each select="cbc:PostalZone">
					<xsl:if test=". != ''">
						<xsl:apply-templates/>
						<xsl:text>&#xA0;</xsl:text>
					</xsl:if>
				</xsl:for-each>
				<xsl:for-each select="cbc:District">
					<xsl:if test=". !=''">
						<xsl:apply-templates/>
						<xsl:text>&#xA0;</xsl:text>
					</xsl:if>
